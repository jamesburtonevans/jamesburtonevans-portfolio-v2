---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects.filter(p => p.data.featured);
---

<section class="work" id="projects">
  <h2 data-nav="Work">My Work</h2>
  <div class="project-grid">
    {featured.map(project => (
      <a href={`/projects/${project.id}`} class="project-card">
        {project.data.cover && (
          <Image src={project.data.cover} alt={project.data.title} />
        )}
        <div class="project-card-body">
          <span class="project-tag">{project.data.category}</span>
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
        </div>
      </a>
    ))}
  </div>
  <a href="/projects" class="view-all">View All Work</a>
</section>