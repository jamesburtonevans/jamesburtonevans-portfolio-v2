---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | James Evans</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-logo">James Evans</a>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/#projects">Work</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
