{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "UX",
        "Development",
        "Music",
        "Academic",
        "3D"
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "cover": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "category",
    "date"
  ]
}